---
const name = "SUNORAPI";
const bio = ""; // 一言コメントをここに書く

const sites = [
  {
    label: "Blog",
    description: "日常・思考の記録",
    href: "#", // TODO: サブドメイン確定後に更新
  },
  {
    label: "Tech",
    description: "技術メモ・開発記録",
    href: "#", // TODO: サブドメイン確定後に更新
  },
];

const externalLinks = [
  { label: "GitHub", href: "https://github.com/SUNORAPI" },
  // { label: "X", href: "https://x.com/SUNORAPI" },
  // { label: "Zenn", href: "https://zenn.dev/SUNORAPI" },
];

// TODO: サブドメイン確定後、blog の RSS or API から取得する
const recentPosts = [
  {
    title: "記事タイトルが入ります",
    date: "2026-05-20",
    excerpt: "記事の概要テキストがここに入ります。数行程度の説明文。",
    href: "#",
    site: "Blog",
  },
  {
    title: "技術記事のタイトル",
    date: "2026-05-18",
    excerpt: "技術的な内容の概要。ライブラリや実装の話など。",
    href: "#",
    site: "Tech",
  },
  {
    title: "別の記事タイトル",
    date: "2026-05-15",
    excerpt: "また別の記事の概要テキストが入ります。",
    href: "#",
    site: "Blog",
  },
];

// TODO: 手動更新 or CMS から取得
const notices = [
  { date: "2026-05-20", text: "サイトを公開しました" },
  { date: "2026-05-18", text: "Tech サイトを追加しました" },
  { date: "2026-05-15", text: "Blog を移行しました" },
];
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{name}</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #fafafa;
        color: #111;
        min-height: 100svh;
      }

      /* ---- layout ---- */

      .layout {
        display: grid;
        grid-template-columns: 1fr;
        grid-template-areas: "center";
        padding: 3rem 1.25rem 4rem;
        max-width: 1100px;
        margin: 0 auto;
      }

      .sidebar-left  { display: none; grid-area: left;   }
      .sidebar-right { display: none; grid-area: right;  }

      .center {
        grid-area: center;
        justify-self: center;
        width: 100%;
        max-width: 360px;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      @media (min-width: 900px) {
        .layout {
          grid-template-columns: 220px minmax(0, 360px) 220px;
          grid-template-areas: "left center right";
          gap: 2.5rem;
          justify-content: center;
        }
        .sidebar-left  { display: block; padding-top: 0.25rem; }
        .sidebar-right { display: block; padding-top: 0.25rem; }
      }

      /* ---- profile (center) ---- */

      .profile {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 2.5rem;
        width: 100%;
      }

      .avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: #e5e7eb;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        user-select: none;
      }

      .name {
        font-size: 1.25rem;
        font-weight: 700;
        letter-spacing: 0.02em;
      }

      .bio {
        font-size: 0.875rem;
        color: #555;
        text-align: center;
        max-width: 280px;
        line-height: 1.6;
      }

      /* ---- site cards (center) ---- */

      .section-label {
        width: 100%;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #888;
        margin-bottom: 0.625rem;
      }

      .cards {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 0.625rem;
        margin-bottom: 2rem;
      }

      .card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.875rem 1rem;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        text-decoration: none;
        color: inherit;
        transition: border-color 0.15s, box-shadow 0.15s;
      }

      .card:hover {
        border-color: #aaa;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
      }

      .card-label { font-size: 0.9375rem; font-weight: 600; }
      .card-desc  { font-size: 0.8125rem; color: #666; margin-top: 0.125rem; }
      .card-arrow { color: #bbb; font-size: 1rem; flex-shrink: 0; }

      /* ---- external links (center) ---- */

      .ext-links {
        width: 100%;
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .ext-link {
        font-size: 0.8125rem;
        color: #555;
        text-decoration: none;
        padding: 0.375rem 0.75rem;
        border: 1px solid #e5e7eb;
        border-radius: 999px;
        transition: border-color 0.15s;
      }

      .ext-link:hover { border-color: #aaa; color: #111; }

      /* ---- sidebar shared ---- */

      .sidebar-title {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #888;
        margin-bottom: 0.875rem;
      }

      /* ---- notices (left) ---- */

      .notice-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      .notice-item {}

      .notice-date {
        font-size: 0.7rem;
        color: #aaa;
        margin-bottom: 0.2rem;
      }

      .notice-text {
        font-size: 0.8125rem;
        color: #333;
        line-height: 1.5;
      }

      /* ---- blog cards (right) ---- */

      .post-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      .post-card {
        display: block;
        padding: 0.75rem;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        text-decoration: none;
        color: inherit;
        transition: border-color 0.15s, box-shadow 0.15s;
      }

      .post-card:hover {
        border-color: #aaa;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
      }

      .post-meta {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.3rem;
      }

      .post-site {
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: #888;
        background: #f3f4f6;
        padding: 0.1rem 0.4rem;
        border-radius: 4px;
      }

      .post-date {
        font-size: 0.7rem;
        color: #bbb;
      }

      .post-title {
        font-size: 0.875rem;
        font-weight: 600;
        line-height: 1.4;
        margin-bottom: 0.3rem;
      }

      .post-excerpt {
        font-size: 0.775rem;
        color: #666;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
    </style>
  </head>
  <body>
    <div class="layout">

      <!-- 左サイドバー：お知らせ・更新一覧 -->
      <aside class="sidebar-left">
        <p class="sidebar-title">お知らせ</p>
        <div class="notice-list">
          {notices.map((n) => (
            <div class="notice-item">
              <p class="notice-date">{n.date}</p>
              <p class="notice-text">{n.text}</p>
            </div>
          ))}
        </div>
      </aside>

      <!-- センター：プロフィール + サイトカード -->
      <main class="center">
        <div class="profile">
          <div class="avatar">👤</div>
          <p class="name">{name}</p>
          {bio && <p class="bio">{bio}</p>}
        </div>

        <p class="section-label">Sites</p>
        <div class="cards">
          {sites.map((site) => (
            <a class="card" href={site.href}>
              <div>
                <div class="card-label">{site.label}</div>
                <div class="card-desc">{site.description}</div>
              </div>
              <span class="card-arrow">→</span>
            </a>
          ))}
        </div>

        <div class="ext-links">
          {externalLinks.map((link) => (
            <a class="ext-link" href={link.href} target="_blank" rel="noopener noreferrer">
              {link.label}
            </a>
          ))}
        </div>
      </main>

      <!-- 右サイドバー：新着記事ブログカード -->
      <aside class="sidebar-right">
        <p class="sidebar-title">新着記事</p>
        <div class="post-list">
          {recentPosts.map((post) => (
            <a class="post-card" href={post.href}>
              <div class="post-meta">
                <span class="post-site">{post.site}</span>
                <span class="post-date">{post.date}</span>
              </div>
              <p class="post-title">{post.title}</p>
              <p class="post-excerpt">{post.excerpt}</p>
            </a>
          ))}
        </div>
      </aside>

    </div>
  </body>
</html>
