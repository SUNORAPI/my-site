---
import { Image } from 'astro:assets';
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '@workspace/ui/layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, series, seriesOrder } = Astro.props;

let seriesPosts: CollectionEntry<'blog'>[] = [];
let prevInSeries: CollectionEntry<'blog'> | null = null;
let nextInSeries: CollectionEntry<'blog'> | null = null;
let currentIndex = -1;

if (series) {
	const all = await getCollection('blog');
	seriesPosts = all
		.filter((p) => p.data.series === series)
		.sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
	currentIndex = seriesPosts.findIndex((p) => p.data.title === title);
	if (currentIndex >= 0) {
		prevInSeries = currentIndex > 0 ? seriesPosts[currentIndex - 1] : null;
		nextInSeries =
			currentIndex < seriesPosts.length - 1 ? seriesPosts[currentIndex + 1] : null;
	}
}
---

<BaseLayout
	title={title}
	siteName="Blog"
	description={description}
	topHref="/"
	nav={[{ label: 'Blog', href: '/blog' }, { label: 'About', href: '/about' }]}
>
	<article>
		{
			heroImage && (
				<div class="hero-image">
					<Image width={1200} height={630} src={heroImage} alt="" />
				</div>
			)
		}

		<header class="article-header">
			{
				series && (
					<a class="series-banner" href={`/series/${encodeURIComponent(series)}/`}>
						シリーズ: {series}
						{seriesOrder !== undefined && <> ・ 第 {seriesOrder} 話</>}
					</a>
				)
			}
			<h1 class="article-title">{title}</h1>
			<p class="article-meta">
				<FormattedDate date={pubDate} />
				{
					updatedDate && (
						<span class="updated">
							（更新: <FormattedDate date={updatedDate} />）
						</span>
					)
				}
			</p>
		</header>

		<div class="prose">
			<slot />
		</div>

		{
			series && seriesPosts.length > 0 && (
				<nav class="series-nav">
					<p class="series-nav-title">シリーズ: {series}</p>
					<ol>
						{seriesPosts.map((p, idx) => (
							<li class={idx === currentIndex ? 'current' : ''}>
								{idx === currentIndex ? (
									<span>
										第 {p.data.seriesOrder ?? idx + 1} 話　{p.data.title}
									</span>
								) : (
									<a href={`/blog/${p.id}/`}>
										第 {p.data.seriesOrder ?? idx + 1} 話　{p.data.title}
									</a>
								)}
							</li>
						))}
					</ol>
				</nav>
			)
		}

		{
			series && (prevInSeries || nextInSeries) && (
				<div class="prev-next">
					{prevInSeries ? (
						<a href={`/blog/${prevInSeries.id}/`} class="prev">
							<div class="label">← 前の話</div>
							<div class="pn-title">{prevInSeries.data.title}</div>
						</a>
					) : (
						<span />
					)}
					{nextInSeries ? (
						<a href={`/blog/${nextInSeries.id}/`} class="next">
							<div class="label">次の話 →</div>
							<div class="pn-title">{nextInSeries.data.title}</div>
						</a>
					) : (
						<span />
					)}
				</div>
			)
		}
	</article>
</BaseLayout>

<style>
	article {
		max-width: 100%;
	}
	.hero-image {
		margin: 0 -1.25rem 2rem;
	}
	.hero-image :global(img) {
		width: 100%;
		height: auto;
		border-radius: 0;
	}
	.article-header {
		margin-bottom: 2.5rem;
	}
	.series-banner {
		display: inline-block;
		font-size: 0.85rem;
		background: var(--color-code-bg);
		color: var(--color-muted);
		padding: 0.25em 0.8em;
		border-radius: 999px;
		margin-bottom: 1rem;
		text-decoration: none;
	}
	.series-banner:hover {
		background: var(--color-border);
		color: var(--color-text);
	}
	.article-title {
		font-size: 1.75rem;
		font-weight: 700;
		line-height: 1.4;
		margin: 0 0 0.5rem;
		color: var(--color-text);
	}
	.article-meta {
		color: var(--color-subtle);
		font-size: 0.85rem;
		margin: 0;
	}
	.updated {
		margin-left: 0.5em;
	}
	.series-nav {
		margin: 3rem 0 1rem;
		padding: 1.2rem;
		border: 1px solid var(--color-border);
		border-radius: 12px;
		background: var(--color-surface);
	}
	.series-nav-title {
		font-size: 0.95rem;
		font-weight: 700;
		margin: 0 0 0.8rem;
		color: var(--color-text);
	}
	.series-nav ol {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.series-nav li {
		padding: 0.35rem 0;
		font-size: 0.95rem;
	}
	.series-nav li a {
		color: var(--color-accent);
		text-decoration: none;
	}
	.series-nav li a:hover {
		text-decoration: underline;
	}
	.series-nav li.current {
		color: var(--color-text);
		font-weight: 700;
	}
	.series-nav li.current::before {
		content: '▶ ';
	}
	.prev-next {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		margin: 2rem 0 0;
		flex-wrap: wrap;
	}
	.prev-next a {
		flex: 1 1 45%;
		padding: 1rem;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		text-decoration: none;
		color: inherit;
		background: var(--color-surface);
		transition: background 0.15s ease;
	}
	.prev-next a:hover {
		background: var(--color-code-bg);
	}
	.prev-next .label {
		font-size: 0.8rem;
		color: var(--color-subtle);
		margin-bottom: 0.3rem;
	}
	.prev-next .pn-title {
		font-size: 0.95rem;
		color: var(--color-text);
		font-weight: 700;
		line-height: 1.5;
	}
	.prev-next .next {
		text-align: right;
	}
</style>
