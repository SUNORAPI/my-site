---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const allPosts = await getCollection('blog');

type Post = (typeof allPosts)[number];

const seriesMap = new Map<string, Post[]>();
const standalonePosts: Post[] = [];

for (const post of allPosts) {
	const series = post.data.series;
	if (series) {
		const arr = seriesMap.get(series) ?? [];
		arr.push(post);
		seriesMap.set(series, arr);
	} else {
		standalonePosts.push(post);
	}
}

const seriesList = [...seriesMap.entries()].map(([name, posts]) => {
	const sorted = [...posts].sort((a, b) => {
		const oa = a.data.seriesOrder ?? 0;
		const ob = b.data.seriesOrder ?? 0;
		return oa - ob;
	});
	return {
		name,
		posts: sorted,
		latestDate: sorted.reduce(
			(max, p) => (p.data.pubDate > max ? p.data.pubDate : max),
			sorted[0].data.pubDate,
		),
	};
});

seriesList.sort((a, b) => b.latestDate.valueOf() - a.latestDate.valueOf());
standalonePosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
			}
			.section-heading {
				font-size: 1.2em;
				margin: 2.5em 0 1em;
				padding-bottom: 0.4em;
				border-bottom: 2px solid rgb(var(--gray-light));
			}
			.section-heading:first-of-type {
				margin-top: 0;
			}
			.card-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 1.5rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.card-grid li a {
				display: block;
				text-decoration: none;
				color: inherit;
				border-radius: 12px;
				overflow: hidden;
				background: #fff;
				border: 1px solid rgb(var(--gray-light));
				transition: transform 0.15s ease, box-shadow 0.15s ease;
				height: 100%;
			}
			.card-grid li a:hover {
				transform: translateY(-2px);
				box-shadow: 0 4px 16px rgba(var(--gray), 25%);
			}
			.thumb {
				display: block;
				width: 100%;
				aspect-ratio: 16 / 9;
				object-fit: cover;
				background: linear-gradient(
					135deg,
					rgb(var(--gray-light)),
					rgba(var(--gray), 0.25)
				);
			}
			.thumb-placeholder {
				display: flex;
				align-items: center;
				justify-content: center;
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			.card-body {
				padding: 1em 1.2em 1.2em;
			}
			.card-title {
				font-size: 1.05em;
				font-weight: 700;
				margin: 0 0 0.4em;
				color: rgb(var(--black));
				line-height: 1.4;
			}
			.card-meta {
				font-size: 0.85em;
				color: rgb(var(--gray));
				margin: 0;
			}
			.card-description {
				font-size: 0.9em;
				color: rgb(var(--gray-dark));
				margin: 0.5em 0 0;
				line-height: 1.6;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.series-badge {
				display: inline-block;
				font-size: 0.75em;
				background: rgba(var(--gray-light), 1);
				color: rgb(var(--gray-dark));
				padding: 0.15em 0.6em;
				border-radius: 999px;
				margin-right: 0.4em;
			}
			.series-block {
				margin-bottom: 2.5em;
				padding: 1.2em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				background: rgba(var(--gray-light), 0.3);
			}
			.series-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				margin-bottom: 1em;
				flex-wrap: wrap;
				gap: 0.5em;
			}
			.series-name {
				font-size: 1.1em;
				font-weight: 700;
				margin: 0;
				color: rgb(var(--black));
			}
			.series-count {
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
			@media (max-width: 720px) {
				.card-grid {
					grid-template-columns: 1fr;
					gap: 1rem;
				}
				.series-block {
					padding: 0.8em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				{
					seriesList.length > 0 && (
						<h2 class="section-heading">シリーズ</h2>
					)
				}
				{
					seriesList.map((series) => (
						<div class="series-block">
							<div class="series-header">
								<h3 class="series-name">{series.name}</h3>
								<span class="series-count">全 {series.posts.length} 話</span>
							</div>
							<ul class="card-grid">
								{series.posts.map((post) => (
									<li>
										<a href={`/blog/${post.id}/`}>
											{post.data.heroImage ? (
												<Image
													class="thumb"
													width={720}
													height={405}
													src={post.data.heroImage}
													alt=""
												/>
											) : (
												<div class="thumb thumb-placeholder">
													<span>No image</span>
												</div>
											)}
											<div class="card-body">
												<p class="card-meta">
													<span class="series-badge">
														第 {post.data.seriesOrder ?? '?'} 話
													</span>
													<FormattedDate date={post.data.pubDate} />
												</p>
												<h4 class="card-title">{post.data.title}</h4>
												<p class="card-description">{post.data.description}</p>
											</div>
										</a>
									</li>
								))}
							</ul>
						</div>
					))
				}

				{
					standalonePosts.length > 0 && (
						<h2 class="section-heading">単発記事</h2>
					)
				}
				<ul class="card-grid">
					{
						standalonePosts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage ? (
										<Image
											class="thumb"
											width={720}
											height={405}
											src={post.data.heroImage}
											alt=""
										/>
									) : (
										<div class="thumb thumb-placeholder">
											<span>No image</span>
										</div>
									)}
									<div class="card-body">
										<p class="card-meta">
											<FormattedDate date={post.data.pubDate} />
										</p>
										<h4 class="card-title">{post.data.title}</h4>
										<p class="card-description">{post.data.description}</p>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
