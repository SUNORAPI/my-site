---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '@workspace/ui/layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

const allPosts = await getCollection('blog');

type Post = (typeof allPosts)[number];

const seriesMap = new Map<string, Post[]>();
const standalonePosts: Post[] = [];

for (const post of allPosts) {
	const series = post.data.series;
	if (series) {
		const arr = seriesMap.get(series) ?? [];
		arr.push(post);
		seriesMap.set(series, arr);
	} else {
		standalonePosts.push(post);
	}
}

const seriesList = [...seriesMap.entries()].map(([name, posts]) => {
	const sorted = [...posts].sort((a, b) => {
		const oa = a.data.seriesOrder ?? 0;
		const ob = b.data.seriesOrder ?? 0;
		return oa - ob;
	});
	return {
		name,
		posts: sorted,
		latestDate: sorted.reduce(
			(max, p) => (p.data.pubDate > max ? p.data.pubDate : max),
			sorted[0].data.pubDate,
		),
	};
});

seriesList.sort((a, b) => b.latestDate.valueOf() - a.latestDate.valueOf());
standalonePosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
	title="記事一覧"
	siteName="Blog"
	description="記事一覧"
	topHref="/"
	nav={[{ label: 'About', href: '/about' }]}
>
	<div class="wide">
		{
			seriesList.length > 0 && (
				<h2 class="section-heading">シリーズ</h2>
			)
		}
		{
			seriesList.map((series) => (
				<section class="series-block">
					<header class="series-header">
						<h3 class="series-name">{series.name}</h3>
						<span class="series-count">全 {series.posts.length} 話</span>
					</header>
					<ul class="card-grid">
						{series.posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage ? (
										<Image
											class="thumb"
											width={720}
											height={405}
											src={post.data.heroImage}
											alt=""
										/>
									) : (
										<div class="thumb thumb-placeholder">
											<span>No image</span>
										</div>
									)}
									<div class="card-body">
										<p class="card-meta">
											<span class="series-badge">
												第 {post.data.seriesOrder ?? '?'} 話
											</span>
											<FormattedDate date={post.data.pubDate} />
										</p>
										<h4 class="card-title">{post.data.title}</h4>
										<p class="card-description">{post.data.description}</p>
									</div>
								</a>
							</li>
						))}
					</ul>
				</section>
			))
		}

		{
			standalonePosts.length > 0 && (
				<h2 class="section-heading">単発記事</h2>
			)
		}
		<ul class="card-grid">
			{
				standalonePosts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`}>
							{post.data.heroImage ? (
								<Image
									class="thumb"
									width={720}
									height={405}
									src={post.data.heroImage}
									alt=""
								/>
							) : (
								<div class="thumb thumb-placeholder">
									<span>No image</span>
								</div>
							)}
							<div class="card-body">
								<p class="card-meta">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<h4 class="card-title">{post.data.title}</h4>
								<p class="card-description">{post.data.description}</p>
							</div>
						</a>
					</li>
				))
			}
		</ul>
	</div>
</BaseLayout>

<style is:global>
	body:has(.wide) {
		--max-content: 920px;
	}
</style>

<style>
	.section-heading {
		font-size: 1.1rem;
		font-weight: 700;
		margin: 2.5rem 0 1rem;
		padding-bottom: 0.4rem;
		border-bottom: 2px solid var(--color-border);
	}
	.section-heading:first-of-type {
		margin-top: 0;
	}
	.series-block {
		margin-bottom: 2.5rem;
		padding: 1.2rem;
		border: 1px solid var(--color-border);
		border-radius: 12px;
		background: var(--color-surface);
	}
	.series-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 1rem;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.series-name {
		font-size: 1.05rem;
		font-weight: 700;
		margin: 0;
		color: var(--color-text);
	}
	.series-count {
		font-size: 0.85rem;
		color: var(--color-subtle);
	}
	.card-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.25rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.card-grid > li > a {
		display: block;
		text-decoration: none;
		color: inherit;
		border-radius: 12px;
		overflow: hidden;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		transition: transform 0.15s ease, box-shadow 0.15s ease;
		height: 100%;
	}
	.card-grid > li > a:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
	}
	.thumb {
		display: block;
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		background: linear-gradient(135deg, #eef0f3, #d8dde4);
	}
	.thumb-placeholder {
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--color-subtle);
		font-size: 0.85rem;
	}
	.card-body {
		padding: 0.9rem 1.1rem 1.1rem;
	}
	.card-title {
		font-size: 0.98rem;
		font-weight: 700;
		margin: 0 0 0.4rem;
		color: var(--color-text);
		line-height: 1.5;
	}
	.card-meta {
		font-size: 0.8rem;
		color: var(--color-subtle);
		margin: 0;
	}
	.card-description {
		font-size: 0.85rem;
		color: var(--color-muted);
		margin: 0.5rem 0 0;
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.series-badge {
		display: inline-block;
		font-size: 0.72rem;
		background: var(--color-code-bg);
		color: var(--color-muted);
		padding: 0.1em 0.6em;
		border-radius: 999px;
		margin-right: 0.4em;
	}
	@media (max-width: 720px) {
		.card-grid {
			grid-template-columns: 1fr;
			gap: 1rem;
		}
		.series-block {
			padding: 0.8rem;
		}
	}
</style>
