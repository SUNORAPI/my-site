---
import { getCollection } from 'astro:content';
import BaseLayout from '@workspace/ui/layouts/BaseLayout.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' });
---

<BaseLayout
  title="Blog"
  siteName="Blog"
  description="日常・思考の記録"
  topHref="#"
  nav={[{ label: 'About', href: '/about' }]}
>
  <h1 class="page-title">記事一覧</h1>

  <ul class="post-list">
    {posts.map((post) => (
      <li>
        <a href={`/blog/${post.id}/`} class="post-item">
          <span class="post-date">{fmt(post.data.pubDate)}</span>
          <span class="post-title">{post.data.title}</span>
          {post.data.description && (
            <span class="post-desc">{post.data.description}</span>
          )}
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .page-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 2rem;
  }

  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-item {
    display: grid;
    grid-template-columns: 6.5rem 1fr;
    grid-template-rows: auto auto;
    column-gap: 1rem;
    align-items: baseline;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .post-item:first-child { border-top: 1px solid var(--color-border); }
  .post-item:hover { opacity: 0.65; }

  .post-date {
    font-size: 0.8rem;
    color: var(--color-subtle);
    grid-row: 1;
    grid-column: 1;
  }

  .post-title {
    font-size: 0.9375rem;
    font-weight: 600;
    grid-row: 1;
    grid-column: 2;
    line-height: 1.5;
  }

  .post-desc {
    font-size: 0.8125rem;
    color: var(--color-muted);
    grid-row: 2;
    grid-column: 2;
    margin-top: 0.2rem;
    line-height: 1.5;
  }
</style>
