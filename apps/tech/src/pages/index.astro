---
import BaseLayout from '@workspace/ui/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Tech"
  siteName="Tech"
  description="技術メモ・開発記録"
  topHref="#"
>
  <h1 class="page-title">Tech</h1>
  <p class="lead">技術メモ・開発記録</p>

  <div class="empty">
    <p>記事を準備中です。</p>
  </div>
</BaseLayout>

<style>
  .page-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .lead {
    font-size: 0.9375rem;
    color: var(--color-muted);
    margin-bottom: 3rem;
  }

  .empty {
    padding: 3rem 0;
    color: var(--color-subtle);
    font-size: 0.875rem;
  }
</style>
